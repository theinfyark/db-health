{
  "name": "db-health",
  "version": "1.0.1",
  "description": "Database health monitoring toolkit for PostgreSQL, MySQL, MongoDB, and Redis — latency, pool metrics, readiness, and health endpoints.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "database",
    "postgres",
    "mysql",
    "mongodb",
    "redis",
    "health",
    "monitoring",
    "healthcheck",
    "health-check",
    "db-monitoring",
    "readiness",
    "liveness",
    "kubernetes",
    "probe",
    "connection-pool",
    "typescript",
    "nodejs"
  ],
  "author": "Anil Kumar <anilachary67@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfyark/db-health.git"
  },
  "bugs": {
    "url": "https://github.com/theinfyark/db-health/issues"
  },
  "homepage": "https://github.com/theinfyark/db-health#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilachary"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.3"
  }
}
